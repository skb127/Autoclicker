<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Autoclicker.ViewModels"
             x:Class="Autoclicker.Views.MainView"
             x:DataType="vm:MainViewModel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
        <TextBlock Text="Multiplatform Autoclicker" FontSize="24" HorizontalAlignment="Center"/>
        
        <Button Content="1. Select Coordinate" 
                Command="{Binding CaptureCoordinateCommand}" 
                IsEnabled="{Binding !IsClicking}"
                HorizontalAlignment="Center"/>
                
        <TextBlock Text="{Binding CoordinatesText}" HorizontalAlignment="Center"/>
        
        <Button Content="2. Start Autoclick (50ms)" 
                Command="{Binding StartAutoclickCommand}" 
                IsEnabled="{Binding !IsClicking}"
                HorizontalAlignment="Center"/>
                
        <Button Content="Stop (Or press ESCAPE)" 
                Command="{Binding StopAutoclickCommand}" 
                IsEnabled="{Binding IsClicking}"
                HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
